{
  "name": "photoforyou",
  "version": "1.0.0",
  "description": "AI 智能照片筛选工具 - 帮你从几百张照片里秒速挑出值得修的那几张",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p src/server/tsconfig.json && node dist/server/index.js\"",
    "dev:frontend": "vite",
    "dev:server": "tsc -p src/server/tsconfig.json && node dist/server/index.js",
    "build:server": "tsc -p src/server/tsconfig.json",
    "build:frontend": "vite build",
    "build": "npm run build:server && npm run build:frontend",
    "start": "node dist/server/index.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "photo",
    "filter",
    "AI",
    "beauty"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mediapipe/face_mesh": "^0.4.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "archiver": "^7.0.1",
    "canvas": "^3.2.3",
    "comlink": "^4.4.0",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "imghash": "^1.1.4",
    "multer": "^1.4.5-lts.1",
    "onnxruntime-node": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^1.4.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.2"
  }
}
