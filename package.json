{
  "name": "photoforyou",
  "version": "1.0.0",
  "description": "AI 智能照片筛选工具 - 帮你从几百张照片里秒速挑出值得修的那几张",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc -p src/main/tsconfig.json && ELECTRON_DEV=true electron .\"",
    "electron:build": "npm run build && electron-builder",
    "lint": "tsc --noEmit && tsc -p src/main/tsconfig.json --noEmit"
  },
  "keywords": [
    "photo",
    "filter",
    "AI",
    "beauty"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mediapipe/face_mesh": "^0.4.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "canvas": "^3.2.3",
    "comlink": "^4.4.0",
    "imghash": "^1.1.4",
    "onnxruntime-node": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.photoforyou.app",
    "productName": "PhotoForYou",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
